# ── Supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_STORAGE_BUCKET=disease-media
VITE_STORAGE_CACHE_CONTROL=3600

# ─── AI Configuration ─────────────────────────────────────
# Provider: google | openai | anthropic | mistral | perplexity | azure
AI_PROVIDER=openai
# API key or Subscription Key for the chosen provider
AI_API_KEY=your-api-key
# google: gemini-2.0-flash | openai: gpt-4o-mini | anthropic: claude-sonnet-4-20250514 | mistral: mistral-large-latest | perplexity: sonar
AI_MODEL=gpt-4o-api
# Custom endpoint (optional — needed for Perplexity, Azure, self-hosted)
# Example: https://apim-xxx.azure-api.net/oai-hps-sw/openaiV3 - for Azure APIM
AI_BASE_URL=your-custom-endpoint-if-needed
# API version (optional — needed for Azure OpenAI, etc.)
AI_API_VERSION=2023-05-15
# Max retry attempts on transient errors
AI_MAX_RETRIES=1

VITE_TRANSLATION_API_URL=https://translate.googleapis.com/translate_a/single
OAUTH_CALLBACK_PATH=your-oauth-callback-path
VITE_DEFAULT_LANGUAGE=en
VITE_ADMIN_PAGE_SIZE=20
VITE_DISEASE_PAGE_SIZE=12
VITE_AI_ENABLED=true
WEATHER_API_URL=your-weather-api-url
WEATHER_API_KEY=your-openweathermap-api-key
